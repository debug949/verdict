# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=        # base64-encoded PEM: base64 -i key.pem | tr -d '\n'
GITHUB_WEBHOOK_SECRET=         # node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upstash Redis (KV — report persistence)
# Provision a free database at https://console.upstash.com
# Then copy the REST URL and token from the database dashboard.
# In production these are set via: vercel env add UPSTASH_REDIS_REST_URL
UPSTASH_REDIS_REST_URL=        # https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=      # your-upstash-rest-token
